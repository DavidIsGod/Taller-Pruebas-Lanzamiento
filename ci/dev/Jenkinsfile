// Dev pipeline (multibranch, runs on every push to feature/* and develop).
// Builds, runs unit + integration tests, builds & pushes Docker images,
// then deploys to the dev namespace in Kubernetes.
pipeline {
  agent any

  options {
    timestamps()
    timeout(time: 30, unit: 'MINUTES')
    buildDiscarder(logRotator(numToKeepStr: '20'))
  }

  parameters {
    choice(name: 'SERVICE',
           choices: ['all','auth','identity','promotion','notification','form','gateway'],
           description: 'Service to build (all = monorepo build)')
  }

  environment {
    REGISTRY      = 'registry.local:5000'
    IMAGE_PREFIX  = 'circleguard'
    GIT_SHA       = "${env.GIT_COMMIT?.take(7) ?: 'local'}"
    KUBECONFIG    = credentials('kubeconfig-dev')
  }

  stages {
    stage('Checkout') {
      steps { checkout scm }
    }

    stage('Static analysis') {
      steps {
        sh './gradlew --no-daemon ktlintCheck detekt || true' // non-blocking in dev
      }
    }

    stage('Unit tests') {
      steps {
        sh './gradlew --no-daemon test'
      }
      post {
        always {
          junit allowEmptyResults: true, testResults: '**/build/test-results/test/*.xml'
        }
      }
    }

    stage('Integration tests') {
      steps {
        // Tagged @Tag("integration"); spawn Testcontainers via Docker socket.
        sh './gradlew --no-daemon integrationTest -Dgroups=integration || ./gradlew --no-daemon test -Pgroups=integration'
      }
      post {
        always {
          junit allowEmptyResults: true, testResults: '**/build/test-results/integrationTest/*.xml'
        }
      }
    }

    stage('Build images') {
      steps {
        script {
          def services = params.SERVICE == 'all' ?
            ['auth','identity','promotion','notification','form','gateway'] :
            [params.SERVICE]
          services.each { s ->
            sh """
              docker build \
                -f services/circleguard-${s}-service/Dockerfile \
                -t ${REGISTRY}/${IMAGE_PREFIX}/${s}-service:dev \
                -t ${REGISTRY}/${IMAGE_PREFIX}/${s}-service:${GIT_SHA} .
              docker push ${REGISTRY}/${IMAGE_PREFIX}/${s}-service:dev
              docker push ${REGISTRY}/${IMAGE_PREFIX}/${s}-service:${GIT_SHA}
            """
          }
        }
      }
    }

    stage('Deploy to dev (k8s)') {
      steps {
        sh '''
          kubectl apply -k k8s/overlays/dev
          kubectl -n circleguard-dev rollout status deployment/auth-service         --timeout=180s
          kubectl -n circleguard-dev rollout status deployment/identity-service     --timeout=180s
          kubectl -n circleguard-dev rollout status deployment/promotion-service    --timeout=180s
          kubectl -n circleguard-dev rollout status deployment/notification-service --timeout=180s
          kubectl -n circleguard-dev rollout status deployment/form-service         --timeout=180s
          kubectl -n circleguard-dev rollout status deployment/gateway-service      --timeout=180s
        '''
      }
    }

    stage('Smoke test') {
      steps {
        sh '''
          AUTH=$(kubectl -n circleguard-dev get svc auth-service -o jsonpath='{.spec.clusterIP}')
          curl -fsS http://${AUTH}:8081/actuator/health
        '''
      }
    }
  }

  post {
    failure { echo "Dev pipeline FAILED for ${env.BRANCH_NAME} @ ${env.GIT_SHA}" }
    success { echo "Dev pipeline OK -> images tagged dev / ${env.GIT_SHA}" }
  }
}
