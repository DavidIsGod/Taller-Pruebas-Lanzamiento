// Stage pipeline (triggered on merge to release/* or release tag candidates).
// Re-uses the dev images, deploys to the stage namespace, and validates
// the deployed system by running E2E + Locust performance tests against it.
pipeline {
  agent any

  options {
    timestamps()
    timeout(time: 60, unit: 'MINUTES')
    buildDiscarder(logRotator(numToKeepStr: '15'))
  }

  environment {
    REGISTRY      = 'registry.local:5000'
    IMAGE_PREFIX  = 'circleguard'
    GIT_SHA       = "${env.GIT_COMMIT?.take(7) ?: 'local'}"
    KUBECONFIG    = '/var/jenkins_home/kube.yaml'
    STAGE_NS      = 'circleguard-stage'
  }

  stages {
    stage('Checkout') { steps { checkout scm } }

    stage('Build & unit + integration tests') {
      steps {
        sh './gradlew --no-daemon clean build'
      }
      post {
        always {
          junit allowEmptyResults: true, testResults: '**/build/test-results/**/*.xml'
        }
      }
    }

    stage('Re-tag & push :stage images') {
      steps {
        script {
          ['auth','identity','promotion','notification','form','gateway'].each { s ->
            sh """
              docker build \
                -f services/circleguard-${s}-service/Dockerfile \
                -t ${REGISTRY}/${IMAGE_PREFIX}/${s}-service:stage \
                -t ${REGISTRY}/${IMAGE_PREFIX}/${s}-service:${GIT_SHA} .
              docker push ${REGISTRY}/${IMAGE_PREFIX}/${s}-service:stage
              docker push ${REGISTRY}/${IMAGE_PREFIX}/${s}-service:${GIT_SHA}
            """
          }
        }
      }
    }

    stage('Deploy to stage (k8s)') {
      steps {
        sh '''
          kubectl apply -k k8s/overlays/stage
          for d in auth-service identity-service promotion-service notification-service form-service gateway-service; do
            kubectl -n ${STAGE_NS} rollout status deployment/${d} --timeout=240s
          done
        '''
      }
    }

    stage('E2E tests against stage') {
      steps {
        sh '''
          AUTH_HOST=$(kubectl -n ${STAGE_NS} get svc auth-service     -o jsonpath='{.spec.clusterIP}')
          GATE_HOST=$(kubectl -n ${STAGE_NS} get svc gateway-service  -o jsonpath='{.spec.clusterIP}')
          FORM_HOST=$(kubectl -n ${STAGE_NS} get svc form-service     -o jsonpath='{.spec.clusterIP}')

          export E2E_AUTH_URL=http://${AUTH_HOST}:8081
          export E2E_GATE_URL=http://${GATE_HOST}:8086
          export E2E_FORM_URL=http://${FORM_HOST}:8085

          python3 -m pip install -r tests/e2e/requirements.txt
          pytest tests/e2e --junitxml=build/e2e-results.xml -v
        '''
      }
      post {
        always {
          junit allowEmptyResults: true, testResults: 'build/e2e-results.xml'
        }
      }
    }

    stage('Performance tests (Locust)') {
      steps {
        sh '''
          AUTH_HOST=$(kubectl -n ${STAGE_NS} get svc auth-service -o jsonpath='{.spec.clusterIP}')
          locust -f tests/performance/locustfile.py \
            --host=http://${AUTH_HOST}:8081 \
            --headless -u 100 -r 20 -t 2m \
            --csv=build/locust --html=build/locust.html
        '''
        archiveArtifacts artifacts: 'build/locust*', allowEmptyArchive: true
      }
    }
  }

  post {
    failure { echo "Stage pipeline FAILED for ${env.BRANCH_NAME} @ ${env.GIT_SHA}" }
    success { echo "Stage validation passed; ready to promote to master." }
  }
}
